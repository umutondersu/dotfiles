[user]
	name = Umut Sahin Onder
	email = umutsonder@gmail.com
[init]
	defaultBranch = main
[alias]
	hist = log --all --decorate --oneline --graph
	uncommit= reset HEAD~1
	recommit= commit --amend --no-edit
	editcommit= commit --amend
	bls= branch -a
	yolo = "!git commit -m \"$(curl -s https://whatthecommit.com/index.txt)\""
	s = "status -s"
	wta = "!f() { git worktree add -b \"$1\" \"../$1\"; }; f"
	wtr = "!f() { git worktree remove \"../$1\"; }; f"
	wtl = "!f() { git worktree list; }; f"
[credential "https://dev.azure.com"]
	useHttpPath = true
[credential]
	helper = 
	helper = manager
	credentialStore = secretservice
[pull]
	rebase = true
# Machine-local overrides (e.g. credentialStore = osxkeychain on macOS)
[include]
	path = ~/.gitconfig.local
